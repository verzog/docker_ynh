## Config panel are available from webadmin > Apps > YOUR_APP > Config Panel Button
## Supports a basic set of possible types as well as any combination of these

version = "1.0"

## (optional) i18n = "config_"

[main]
name.en = "Main configuration"
name.fr = "Configuration principale"

    ## (optional) If you need to trigger a service restart or app reload
    ## after a specific section is saved, you can use the following syntax:
    # services = ["nginx", "__APP__"]

    [main.customization]
    name.en = "Customization"
    name.fr = "Personnalisation"

        [main.customization.container_name]
        ask.en = "Container name"
        ask.fr = "Nom du conteneur"
        type = "string"
        bind = "settings"

        [main.customization.docker_options]
        ask.en = "Additional Docker options"
        ask.fr = "Options Docker supplémentaires"
        help.en = "Extra flags passed to 'docker run' (e.g. -p 127.0.0.1:8080:80 -e MY_VAR=value)"
        help.fr = "Options supplémentaires passées à 'docker run' (ex. -p 127.0.0.1:8080:80 -e MA_VAR=valeur)"
        type = "string"
        optional = true
        bind = "settings"
