#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# REMOVE YUNOHOST SERVICE INTEGRATION
#=================================================
ynh_script_progression "Removing system integrations..."

yunohost service remove "$app" 2>/dev/null || true

ynh_config_remove_systemd

#=================================================
# STOP AND REMOVE DOCKER CONTAINER
#=================================================
ynh_script_progression "Stopping and removing Docker container..."

if docker ps --filter "name=^${app}$" --format "{{.ID}}" 2>/dev/null | grep -q .; then
    docker stop "$app" 2>/dev/null || true
    sleep 1
fi

docker rm "$app" 2>/dev/null || true

#=================================================
# END OF SCRIPT
#=================================================
ynh_script_progression "Removal of $app completed"
