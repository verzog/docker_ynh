#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# GRANT APP USER ACCESS TO DOCKER
#=================================================
ynh_script_progression "Configuring system user..."

# Add the app system user to the docker group so it can run docker commands
# without requiring root. The systemd service runs as this user.
usermod -aG docker "$app"

#=================================================
# ENSURE DOCKER IS AVAILABLE
#=================================================
ynh_script_progression "Checking Docker availability..."

if ! command -v docker &>/dev/null; then
    ynh_die "Docker is not installed. Please install docker.io via your package manager before using this app."
fi

if ! ynh_systemctl --service="docker" --action="is-active" &>/dev/null; then
    ynh_script_progression "Starting Docker daemon..."
    ynh_systemctl --service="docker" --action="start"
fi

#=================================================
# PULL DOCKER IMAGE WITH RETRY LOGIC
#=================================================
ynh_script_progression "Pulling Docker image $image..."

pull_success=false
for attempt in 1 2 3; do
    if docker pull "$image" 2>&1; then
        pull_success=true
        break
    fi

    if [ $attempt -lt 3 ]; then
        ynh_print_warn "Pull attempt $attempt failed. Retrying in 5 seconds..."
        sleep 5
    fi
done

if [ "$pull_success" = false ]; then
    ynh_die "Failed to pull Docker image '$image' after 3 attempts. Check that:
  - The image exists on Docker Hub (or your registry)
  - Your internet connection is working
  - Docker daemon is running

  You can manually test with: docker pull $image"
fi

#=================================================
# COMPUTE DOCKER RUN CONFIGURATION
#=================================================
ynh_script_progression "Computing container configuration..."

compute_docker_config "$restart_policy" "$use_data_volume" "$data_dir"

ynh_app_setting_set --key=systemd_restart --value="$systemd_restart"
ynh_app_setting_set --key=docker_volume_opts --value="$docker_volume_opts"
ynh_app_setting_set --key=restart_policy --value="$restart_policy"
ynh_app_setting_set --key=use_data_volume --value="$use_data_volume"

#=================================================
# CONFIGURE SYSTEMD SERVICE
#=================================================
ynh_script_progression "Configuring systemd service..."

ynh_config_add_systemd

yunohost service add "$app" \
    --description="Docker container: $container_name ($image)" \
    --log="journalctl -u $app -o cat"

#=================================================
# START SERVICE
#=================================================
ynh_script_progression "Starting Docker container..."

ynh_systemctl --service="$app" --action="start"

sleep 2
if ! ynh_systemctl --service="$app" --action="is-active" &>/dev/null; then
    ynh_print_warn "Container started but exited immediately. Check logs with:"
    ynh_print_warn "  journalctl -u $app -n 50"
fi

#=================================================
# END OF SCRIPT
#=================================================
ynh_script_progression "Installation of $app completed"
