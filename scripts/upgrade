#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# STOP SERVICE
#=================================================
ynh_script_progression "Stopping $app's systemd service..."

ynh_systemctl --service="$app" --action="stop"

#=================================================
# PULL LATEST IMAGE
#=================================================
ynh_script_progression "Pulling latest Docker image $image..."

pull_success=false
for attempt in 1 2 3; do
    if docker pull "$image" 2>&1; then
        pull_success=true
        break
    fi

    if [ $attempt -lt 3 ]; then
        ynh_print_warn "Pull attempt $attempt failed. Retrying in 5 seconds..."
        sleep 5
    fi
done

if [ "$pull_success" = false ]; then
    ynh_die "Failed to pull Docker image '$image' after 3 attempts."
fi

docker rm "$app" 2>/dev/null || true

#=================================================
# RECOMPUTE CONFIGURATION
#=================================================
ynh_script_progression "Reapplying container configuration..."

restart_policy=$(ynh_app_setting_get --key=restart_policy)
use_data_volume=$(ynh_app_setting_get --key=use_data_volume)
container_port=$(ynh_app_setting_get --key=container_port)

compute_docker_config "$restart_policy" "$use_data_volume" "$data_dir"

ynh_app_setting_set --key=systemd_restart --value="$systemd_restart"
ynh_app_setting_set --key=docker_volume_opts --value="$docker_volume_opts"

#=================================================
# UPDATE NGINX AND SYSTEMD CONFIGS
#=================================================
ynh_script_progression "Upgrading system configurations..."

ynh_config_add_nginx
ynh_config_add_systemd

yunohost service add "$app" \
    --description="Docker container: $image" \
    --log="journalctl -u $app -o cat"

#=================================================
# START SERVICE
#=================================================
ynh_script_progression "Starting $app's systemd service..."

ynh_systemctl --service="$app" --action="start"

if ! wait_for_port "$port" 30; then
    ynh_print_warn "Container did not bind to port $port within 30 seconds. Check logs with:"
    ynh_print_warn "  journalctl -u $app -n 50"
fi

#=================================================
# END OF SCRIPT
#=================================================
ynh_script_progression "Upgrade of $app completed"
