#!/bin/bash

source ../settings/scripts/_common.sh
source /usr/share/yunohost/helpers

#=================================================
# GRANT APP USER ACCESS TO DOCKER
#=================================================
ynh_script_progression "Configuring system user..."

usermod -aG docker "$app"

#=================================================
# ENSURE DOCKER IS AVAILABLE
#=================================================
ynh_script_progression "Checking Docker availability..."

if ! command -v docker &>/dev/null; then
    ynh_die "Docker is not installed. Please install docker.io before restoring this app."
fi

#=================================================
# PULL DOCKER IMAGE
#=================================================
ynh_script_progression "Pulling Docker image $image..."

pull_success=false
for attempt in 1 2 3; do
    if docker pull "$image" 2>&1; then
        pull_success=true
        break
    fi

    if [ $attempt -lt 3 ]; then
        ynh_print_warn "Pull attempt $attempt failed. Retrying in 5 seconds..."
        sleep 5
    fi
done

if [ "$pull_success" = false ]; then
    ynh_die "Failed to pull Docker image '$image' after 3 attempts during restore."
fi

#=================================================
# RESTORE DATA DIRECTORY
#=================================================
ynh_script_progression "Restoring persistent data volume..."

if [ -d "$YNH_APP_BACKUP_DIR$data_dir" ]; then
    ynh_restore_file --origin_path="$data_dir" --dest_path="$data_dir"
fi

#=================================================
# RESTORE SYSTEM CONFIGURATION
#=================================================
ynh_script_progression "Restoring system configurations..."

ynh_restore_file --origin_path="/etc/nginx/conf.d/$domain.d/$app.conf"
ynh_restore_file --origin_path="/etc/systemd/system/$app.service"

systemctl daemon-reload
systemctl enable "$app.service" --quiet

#=================================================
# ENSURE DOCKER NETWORK EXISTS
#=================================================
docker_network=$(ynh_app_setting_get --key=docker_network)
if [ -n "$docker_network" ]; then
    ynh_script_progression "Ensuring Docker network '$docker_network' exists..."
    docker network create "$docker_network" 2>/dev/null || true
fi

#=================================================
# REAPPLY CONTAINER CONFIGURATION
#=================================================
ynh_script_progression "Reapplying container configuration..."

restart_policy=$(ynh_app_setting_get --key=restart_policy)
use_data_volume=$(ynh_app_setting_get --key=use_data_volume)
mount_docker_socket=$(ynh_app_setting_get --key=mount_docker_socket)

compute_docker_config "$restart_policy" "$use_data_volume" "$data_dir" "$mount_docker_socket" "$docker_network"

ynh_app_setting_set --key=docker_restart_policy --value="$docker_restart_policy"
ynh_app_setting_set --key=docker_volume_opts --value="$docker_volume_opts"
ynh_app_setting_set --key=docker_network_opt --value="$docker_network_opt"

#=================================================
# RELOAD NGINX
#=================================================

ynh_systemctl --service="nginx" --action="reload"

#=================================================
# REGISTER SERVICE WITH YUNOHOST
#=================================================
ynh_script_progression "Registering service with YunoHost..."

image=$(ynh_app_setting_get --key=image)

yunohost service add "$app" \
    --description="Docker container: $image"

#=================================================
# START SERVICE
#=================================================
ynh_script_progression "Starting Docker container..."

ynh_systemctl --service="$app" --action="start"

sleep 2

if ! ynh_systemctl --service="$app" --action="is-active" &>/dev/null; then
    ynh_print_warn "Container started but exited immediately. Check logs with:"
    ynh_print_warn "  journalctl -u $app -n 50"
fi

#=================================================
# END OF SCRIPT
#=================================================
ynh_script_progression "Restoration of $app completed"
